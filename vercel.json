{
  "redirects": [
    {
      "source": "/",
      "destination": "/website",
      "permanent": false
    }
  ],
  "functions": {
    "api/cron/keep-alive/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 12 */5 * *"
    }
  ]
}
